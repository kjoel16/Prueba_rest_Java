sw.Restart();
_logger.LogInformation("--> StartConsult CYBIPRP");

const string sql = @"
    SELECT *
    FROM CYBERDTA.CYBIPRP
    WHERE ESTADO_IMPUESTO = @estado";

var response = await database.Connection.QueryAsync(
    sql,
    new { estado = estadoImpuesto.Value });

sw.Stop();
_logger.LogInformation("--> EndConsult CYBIPRP {Elapsed}ms", sw.Elapsed.TotalMilliseconds);

var registros = response.ToList();

if (!registros.Any())
{
    return listaCabecera;
}

// Acceder a campos dinámicamente
foreach (var row in registros)
{
    string codigo = row.CODIGO;        // nombre exacto de la columna en DB2
    decimal monto = row.MONTO;
    DateTime fecha = row.FECHA_CREACION;
    // ...
}
