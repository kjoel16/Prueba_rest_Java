public async Task<Data> ConsultaCabecera(EasyParameter estadoImpuesto, int anio /*, ...*/)
{
    Data listaCabecera = new Data();

    // -- 1. Consultar cabecera --
    // ANTES: ServiceQueryStringGenerator + EasyCrudModels.SelectExecute sobre CYBERDTA.CYBIPRP
    // AHORA: QueryBuilder<CYBIPRP> + Dapper async (misma tabla)
    var queryCabecera = new QueryBuilder<CYBIPRP>(db2Options)
        .Select()
        .Where(item => item.EstadoImpuesto == estadoImpuesto.Value) // ajusta al nombre real de la propiedad
        .Build();

    sw.Restart();
    _logger.LogInformation("--> StartConsult CYBIPRP");
    var response = await database.Connection.QueryAsync<CYBIPRP>(
        queryCabecera.Sql,
        queryCabecera.ToDapperParameters());
    sw.Stop();
    _logger.LogInformation("--> EndConsult CYBIPRP {Elapsed}ms", sw.Elapsed.TotalMilliseconds);

    var registros = response.ToList();

    // -- 2. Validación temprana --
    // ANTES: if (Count==0) {} else if (Utilitarios.ValidarRegistros(...)) { ... }
    //        ValidarRegistros revisaba _defaultError cuando Count==1.
    // AHORA: chequeo directo sobre la lista tipada, sin helper ni GetValue.
    if (!registros.Any())
    {
        return listaCabecera;
    }

    // -- 3. Armado de la respuesta --
    listaCabecera = CrearListaSalida(registros, Diccionario(), "En...");
    listaCabecera = Detalles(listaCabecera, anio);

    return listaCabecera;
}
